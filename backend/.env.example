# ── 应用基础配置 ──
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Anthropic Claude API ──
ANTHROPIC_API_KEY=sk-ant-xxxxx
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=4096

# ── StarRocks 连接（只读账号） ──
STARROCKS_HOST=10.x.x.x
STARROCKS_PORT=9030
STARROCKS_USER=readonly_user
STARROCKS_PASSWORD=xxxx
STARROCKS_READ_TIMEOUT=30

# ── 公司数据平台 API（元数据查询：Hive + StarRocks 表结构） ──
TDATA_API_BASE=https://your-data-platform/api
TDATA_API_TOKEN=bearer-token-here

# ── SQLite（存储用户/映射数据） ──
SQLITE_PATH=/app/data/platform.db

# ── CORS（前端地址，多个用逗号分隔） ──
CORS_ORIGINS=http://localhost:5173,http://your-domain.com
